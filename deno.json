{
    "nodeModulesDir": "auto",
    "tasks": {
        "build": "cd submodules/client && deno run --allow-read=. --allow-write=. --allow-run --allow-env npm:esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
        "prod": "cd submodules/client && deno run --allow-read=. --allow-write=. --allow-run --allow-env npm:esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
        "lint": "cd submodules/client && deno lint src/",
        "check": "cd submodules/client && deno check src/",
        "fmt": "cd submodules/client && deno fmt src/"
    },
    "fmt": {
        "include": ["submodules/client/src/"],
        "useTabs": true,
        "lineWidth": 120
    },
    "lint": {
        "include": ["submodules/client/src/"]
    },
    "compilerOptions": {
        "strict": true
    }
}