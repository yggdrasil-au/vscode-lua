{
	"compilerOptions": {
		"module": "node20",
		"target": "ES2022",
		"outDir": "out",
		"rootDir": ".",
		"lib": ["ES2022"],
		"types": ["node", "vscode"],
		"sourceMap": true,
		"strict": true,
		"allowJs": true,
		"skipLibCheck": true,
		"noEmit": true,
		"allowImportingTsExtensions": true
	},
	"include": ["src", "3rd"],
	"exclude": ["node_modules", ".vscode-test"]
}
