{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-extension1",
			"type": "shell",
			"command": "deno",
			"args": [
				"task",
				"build"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "build-extension3",
			"type": "shell",
			"command": "deno",
			"args": [
				"task",
				"prod"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
            "label": "build-extension2",
            "type": "shell",
            "command": "./build.ps1",
            "args": [
                "auto"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
		{
            "label": "Fullbuild",
            "type": "shell",
            "command": "./build.ps1",
            "args": [
                "noprompt"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}